<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="debug_msg_enabled" default="false"/>
  <arg name="use_sim" default="false"/>
  <include file="$(find marslite_control)/launch/motion_controller_teleoperation.launch">
    <arg name="debug_msg_enabled" value="$(arg debug_msg_enabled)"/>
    <arg name="use_sim" value="$(arg use_sim)"/>
    <arg name="use_shared_controller" value="true"/>
  </include>

  <arg name="experiment_id" default="1"/>
  <arg name="shared_control_enabled" default="true"/>
  <rosparam file="$(find marslite_control)/config/shared_control.yaml" command="load"/>
  <node name="shared_control_node" pkg="marslite_control" type="shared_control_node" output="screen">
    <param name="experiment_id" value="$(arg experiment_id)"/>
    <param name="use_sim" value="$(arg use_sim)"/>
    <param name="shared_control_enabled" value="$(arg shared_control_enabled)"/>
  </node>
</launch>